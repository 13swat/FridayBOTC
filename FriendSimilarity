}

- { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

html, body {
background: var(–bg);
color: var(–ink);
font-family: ‘Manrope’, sans-serif;
font-weight: 400;
overflow-x: hidden;
-webkit-text-size-adjust: 100%;
}

body {
background:
radial-gradient(1200px 800px at 20% -10%, rgba(240, 169, 135, 0.08), transparent 60%),
radial-gradient(900px 700px at 110% 110%, rgba(178, 144, 214, 0.07), transparent 60%),
var(–bg);
min-height: 100vh;
padding: var(–pad-y) var(–pad-x) calc(var(–pad-y) + 16px);
}

header {
display: grid;
grid-template-columns: 1fr auto;
gap: 24px;
align-items: end;
border-bottom: 1px solid var(–rule);
padding-bottom: 22px;
margin-bottom: 22px;
}
.eyebrow {
font-family: ‘JetBrains Mono’, monospace;
font-size: clamp(9.5px, 2.4vw, 11px);
letter-spacing: 0.22em;
color: var(–ink-faint);
text-transform: uppercase;
margin-bottom: 10px;
line-height: 1.4;
}
h1 {
font-family: ‘Fraunces’, serif;
font-weight: 400;
font-size: clamp(30px, 8vw, 64px);
line-height: 1;
letter-spacing: -0.02em;
font-variation-settings: “opsz” 96;
}
h1 em { font-style: italic; font-weight: 300; color: var(–c3); }
.meta {
text-align: right;
color: var(–ink-dim);
font-size: 12px;
line-height: 1.6;
font-family: ‘JetBrains Mono’, monospace;
}
.meta strong { color: var(–ink); font-weight: 500; }

@media (max-width: 720px) {
header { grid-template-columns: 1fr; gap: 16px; align-items: start; }
.meta {
text-align: left;
font-size: 11px;
line-height: 1.7;
padding-top: 12px;
border-top: 1px solid var(–rule);
}
}

.toolbar {
display: flex; align-items: center; gap: 14px;
margin-bottom: 16px; flex-wrap: wrap;
}
.toggle {
display: inline-flex;
border: 1px solid var(–line);
border-radius: 999px;
padding: 3px;
background: var(–bg-2);
}
.toggle button {
background: transparent;
color: var(–ink-dim);
border: none;
padding: 10px 18px;
cursor: pointer;
border-radius: 999px;
font-family: ‘JetBrains Mono’, monospace;
font-size: 11.5px;
letter-spacing: 0.1em;
text-transform: uppercase;
transition: all 0.2s ease;
min-height: 38px;
}
.toggle button.active { background: var(–ink); color: var(–bg); }
.legend {
display: flex; gap: 12px; flex-wrap: wrap;
font-size: 11.5px; color: var(–ink-dim);
font-family: ‘JetBrains Mono’, monospace;
}
.legend .swatch {
display: inline-flex; align-items: center; gap: 6px;
cursor: pointer; user-select: none;
padding: 4px 2px; min-height: 26px;
transition: opacity 0.2s;
}
.legend .swatch:hover { color: var(–ink); }
.legend .swatch.dim { opacity: 0.35; }
.legend .dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }

.stage {
display: grid;
grid-template-columns: minmax(0, 1fr) 320px;
gap: 26px;
align-items: start;
}
@media (max-width: 900px) {
.stage { grid-template-columns: 1fr; gap: 18px; }
}

.viz-wrap {
position: relative;
background:
radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.025), transparent 70%),
var(–bg-2);
border-radius: 16px;
border: 1px solid var(–rule);
overflow: hidden;
aspect-ratio: 1 / 1;
max-height: 78vh;
touch-action: none;
}
@media (max-width: 720px) {
.viz-wrap { aspect-ratio: 4 / 5; max-height: 70vh; border-radius: 12px; }
}
svg { width: 100%; height: 100%; display: block; cursor: grab; }
svg:active { cursor: grabbing; }

.hint {
position: absolute; bottom: 12px; left: 14px;
color: var(–ink-faint);
font-family: ‘JetBrains Mono’, monospace;
font-size: 10px;
letter-spacing: 0.08em;
text-transform: uppercase;
pointer-events: none;
}

.panel {
position: sticky; top: 24px;
background: var(–bg-2);
border: 1px solid var(–rule);
border-radius: 16px;
padding: 22px 22px 24px;
min-height: 420px;
}
@media (max-width: 900px) {
.panel { position: static; min-height: 0; padding: 20px 18px 22px; border-radius: 12px; }
}
.panel .label {
font-family: ‘JetBrains Mono’, monospace;
font-size: 10.5px;
letter-spacing: 0.2em;
color: var(–ink-faint);
text-transform: uppercase;
margin-bottom: 8px;
}
.panel h2 {
font-family: ‘Fraunces’, serif;
font-weight: 500;
font-size: clamp(26px, 5vw, 30px);
margin-bottom: 4px;
letter-spacing: -0.01em;
font-variation-settings: “opsz” 72;
line-height: 1.1;
word-break: break-word;
}
.panel .cluster-tag {
display: inline-flex; align-items: center; gap: 6px;
font-family: ‘JetBrains Mono’, monospace;
font-size: 11px;
color: var(–ink-dim);
margin-bottom: 18px;
}
.panel .cluster-tag .dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }

.traits { margin-bottom: 22px; }
.trait {
display: grid;
grid-template-columns: 88px 1fr 38px;
gap: 10px; align-items: center;
margin-bottom: 9px;
}
.trait-name {
font-family: ‘JetBrains Mono’, monospace;
font-size: 10.5px;
color: var(–ink-dim);
letter-spacing: 0.05em;
}
.trait-bar {
height: 6px;
background: rgba(255,255,255,0.05);
border-radius: 3px;
overflow: hidden;
position: relative;
}
.trait-bar > span {
display: block; height: 100%; border-radius: 3px;
transition: width 0.6s cubic-bezier(0.22, 1, 0.36, 1);
}
.trait-val {
font-family: ‘JetBrains Mono’, monospace;
font-size: 11px; color: var(–ink); text-align: right;
}

.panel h3 {
font-family: ‘JetBrains Mono’, monospace;
font-size: 10.5px; letter-spacing: 0.2em;
color: var(–ink-faint); text-transform: uppercase;
margin: 18px 0 8px;
font-weight: 500;
}
.matches { list-style: none; }
.matches li {
display: flex; justify-content: space-between; align-items: center;
padding: 11px 0;
border-bottom: 1px solid var(–rule);
cursor: pointer;
transition: padding 0.18s ease, color 0.2s;
min-height: 44px;
}
.matches li:last-child { border-bottom: none; }
.matches li:hover { padding-left: 6px; color: var(–c3); }
.matches li:active { color: var(–c3); }
.matches .rank {
color: var(–ink-faint);
font-family: ‘JetBrains Mono’, monospace;
font-size: 11px; margin-right: 12px;
}
.matches .name {
font-family: ‘Fraunces’, serif;
font-size: 16px; flex: 1;
}
.matches .dist {
font-family: ‘JetBrains Mono’, monospace;
font-size: 11px; color: var(–ink-dim);
}

.placeholder {
color: var(–ink-faint);
font-family: ‘Fraunces’, serif;
font-style: italic;
font-size: 17px;
line-height: 1.5;
max-width: 280px;
}

.heatmap-wrap { display: none; }
.heatmap-wrap.active { display: block; }
.network-wrap.hidden { display: none; }
.heatmap-wrap svg text {
font-family: ‘JetBrains Mono’, monospace;
font-size: 9px;
fill: var(–ink-dim);
}
@media (max-width: 720px) {
.heatmap-wrap svg text { font-size: 8px; }
}

.footer {
margin-top: 26px; padding-top: 18px;
border-top: 1px solid var(–rule);
display: flex; justify-content: space-between;
color: var(–ink-faint);
font-family: ‘JetBrains Mono’, monospace;
font-size: 10.5px;
letter-spacing: 0.1em;
text-transform: uppercase;
flex-wrap: wrap; gap: 10px;
}
@media (max-width: 720px) { .footer { font-size: 9.5px; } }

.link { stroke-linecap: round; transition: stroke-opacity 0.2s; }
.node-group { cursor: pointer; }
.node-group circle.hit { fill: transparent; }
.node-group circle.visible {
transition: stroke-width 0.18s ease, opacity 0.2s ease;
}
.node-label {
font-family: ‘Fraunces’, serif;
font-size: 12.5px;
fill: var(–ink);
pointer-events: none;
paint-order: stroke;
stroke: var(–bg-2);
stroke-width: 3px;
stroke-linejoin: round;
font-weight: 500;
letter-spacing: -0.01em;
}
@media (max-width: 720px) {
.node-label { font-size: 11px; stroke-width: 2.5px; }
}
.node-label.dim { opacity: 0.25; }
.node-group.faded circle.visible { opacity: 0.18; }
.node-group.selected circle.visible { stroke: var(–ink) !important; stroke-width: 2.5px; }
.link.highlight { stroke-opacity: 0.95; }
.link.faded { stroke-opacity: 0.04; }

.tooltip {
position: fixed; pointer-events: none;
background: var(–bg);
border: 1px solid var(–ink-faint);
color: var(–ink);
padding: 8px 12px;
font-family: ‘JetBrains Mono’, monospace;
font-size: 11px;
border-radius: 8px;
opacity: 0;
transition: opacity 0.15s;
z-index: 50;
white-space: nowrap;
max-width: calc(100vw - 24px);
}
.tooltip.show { opacity: 1; }
@media (hover: none) { .tooltip { display: none; } }
</style>

</head>
