const CLUSTER_COLOR = {
  1: getComputedStyle(document.documentElement).getPropertyValue('--c1').trim(),
  2: getComputedStyle(document.documentElement).getPropertyValue('--c2').trim(),
  3: getComputedStyle(document.documentElement).getPropertyValue('--c3').trim(),
  4: getComputedStyle(document.documentElement).getPropertyValue('--c4').trim(),
  5: getComputedStyle(document.documentElement).getPropertyValue('--c5').trim(),
};
const CLUSTER_NAMES = {
  1: "Warm reflective",
  2: "Bold & decisive",
  3: "Easy-going & light",
  4: "Steady analytical",
  5: "Anchored & loyal",
};

const isTouch = matchMedia('(hover: none)').matches;
if (isTouch) {
  document.getElementById('net-hint').textContent = 'Tap a name · pinch to zoom · drag to move';
}

const legendEl = document.getElementById('legend');
const dimmed = new Set();
Object.keys(CLUSTER_COLOR).forEach(k => {
  const s = document.createElement('span');
  s.className = 'swatch';
  s.dataset.cluster = k;
  s.innerHTML = `<span class="dot" style="background:${CLUSTER_COLOR[k]}"></span>${CLUSTER_NAMES[k]}`;
  s.addEventListener('click', () => {
    if (dimmed.has(+k)) { dimmed.delete(+k); s.classList.remove('dim'); }
    else { dimmed.add(+k); s.classList.add('dim'); }
    applyDim();
  });
  legendEl.appendChild(s);
});

const svg = d3.select('#network');
const wrap = document.getElementById('network-wrap');
const W = () => wrap.clientWidth;
const H = () => wrap.clientHeight;

let nodes = DATA.nodes.map(d => ({
  ...d,
  x: d.x * 0.4 * Math.min(W(), H()) + W()/2,
  y: d.y * 0.4 * Math.min(W(), H()) + H()/2
}));
const nodesById = new Map(nodes.map(n => [n.id, n]));
const links = DATA.edges.map(e => ({ ...e }));

const root = svg.append('g').attr('class', 'root');
root.append('g').attr('class', 'links');
root.append('g').attr('class', 'nodes');

const zoom = d3.zoom()
  .scaleExtent([0.5, 4])
  .filter(event => {
    if (event.target.closest('.node-group')) return false;
    return true;
  })
  .on('zoom', (event) => { root.attr('transform', event.transform); });
svg.call(zoom);

const minDist = d3.min(links, d => d.distance);
const maxDist = d3.max(links, d => d.distance);
const linkOpacity = d3.scaleLinear().domain([minDist, maxDist]).range([0.6, 0.12]);
const linkWidth = d3.scaleLinear().domain([minDist, maxDist]).range([2.4, 0.6]);

const sim = d3.forceSimulation(nodes)
  .force('link', d3.forceLink(links).id(d => d.id).distance(d => 30 + d.distance * 60).strength(0.55))
  .force('charge', d3.forceManyBody().strength(-150))
  .force('center', d3.forceCenter(W()/2, H()/2).strength(0.05))
  .force('collide', d3.forceCollide().radius(22))
  .alphaDecay(0.025);

const linkSel = root.select('.links').selectAll('line')
  .data(links).join('line')
  .attr('class', 'link')
  .attr('stroke', '#f0e6d2')
  .attr('stroke-opacity', d => linkOpacity(d.distance))
  .attr('stroke-width', d => linkWidth(d.distance));

const VIS_R = 7;
const HIT_R = isTouch ? 22 : 14;

const nodeSel = root.select('.nodes').selectAll('.node-group')
  .data(nodes, d => d.id).join('g')
  .attr('class', 'node-group')
  .call(d3.drag()
    .on('start', (e, d) => { if (!e.active) sim.alphaTarget(0.3).restart(); d.fx = d.x; d.fy = d.y; })
    .on('drag',  (e, d) => { d.fx = e.x; d.fy = e.y; })
    .on('end',   (e, d) => { if (!e.active) sim.alphaTarget(0); d.fx = null; d.fy = null; })
  );

nodeSel.append('circle').attr('class', 'hit').attr('r', HIT_R);

nodeSel.append('circle')
  .attr('class', 'visible')
  .attr('r', VIS_R)
  .attr('fill', d => CLUSTER_COLOR[d.cluster])
  .attr('stroke', 'rgba(20,17,15,0.7)')
  .attr('stroke-width', 1.5);

nodeSel.append('text')
  .attr('class', 'node-label')
  .attr('dy', -VIS_R - 6)
  .attr('text-anchor', 'middle')
  .text(d => d.id);

const tooltip = document.getElementById('tooltip');

function positionTooltip(e) {
  const pad = 14;
  let x = e.clientX + pad, y = e.clientY + pad;
  const tw = tooltip.offsetWidth, th = tooltip.offsetHeight;
  if (x + tw > window.innerWidth - 8)  x = e.clientX - tw - pad;
  if (y + th > window.innerHeight - 8) y = e.clientY - th - pad;
  tooltip.style.left = Math.max(8, x) + 'px';
  tooltip.style.top  = Math.max(8, y) + 'px';
}

nodeSel
  .on('mouseenter', function(e, d) {
    if (isTouch) return;
    tooltip.classList.add('show');
    tooltip.innerHTML = `<strong>${d.id}</strong> · ${CLUSTER_NAMES[d.cluster]}`;
  })
  .on('mousemove', e => { if (!isTouch) positionTooltip(e); })
  .on('mouseleave', () => tooltip.classList.remove('show'))
  .on('click', (e, d) => { e.stopPropagation(); selectNode(d.id); });

sim.on('tick', () => {
  linkSel
    .attr('x1', d => d.source.x).attr('y1', d => d.source.y)
    .attr('x2', d => d.target.x).attr('y2', d => d.target.y);
  nodeSel.attr('transform', d => `translate(${d.x},${d.y})`);
});

function selectNode(id) {
  const d = nodesById.get(id);
  if (!d) return;

  const neighbors = new Set([id]);
  links.forEach(l => {
    if (l.source.id === id) neighbors.add(l.target.id);
    if (l.target.id === id) neighbors.add(l.source.id);
  });

  nodeSel.classed('faded', n => !neighbors.has(n.id))
         .classed('selected', n => n.id === id);
  nodeSel.selectAll('text').classed('dim', n => !neighbors.has(n.id));
  linkSel.classed('highlight', l => l.source.id === id || l.target.id === id)
         .classed('faded', l => !(l.source.id === id || l.target.id === id));

  document.getElementById('sel-name').textContent = d.id;
  document.getElementById('sel-cluster').innerHTML =
    `<span class="dot" style="background:${CLUSTER_COLOR[d.cluster]}"></span><span>${CLUSTER_NAMES[d.cluster]}</span>`;

  const body = document.getElementById('sel-body');
  const traitRows = Object.entries(d.scores).map(([k, v]) => {
    const pct = ((v - 1) / 3) * 100;
    return `<div class="trait">
      <div class="trait-name">${k}</div>
      <div class="trait-bar"><span style="width:${pct}%; background:${CLUSTER_COLOR[d.cluster]}"></span></div>
      <div class="trait-val">${v.toFixed(2)}</div>
    </div>`;
  }).join('');
  const matchRows = d.top_matches.map((m, i) => `
    <li data-name="${m.name}">
      <span><span class="rank">0${i+1}</span><span class="name">${m.name}</span></span>
      <span class="dist">d = ${m.distance}</span>
    </li>`).join('');

  body.innerHTML = `
    <div class="traits">${traitRows}</div>
    <h3>Closest matches</h3>
    <ul class="matches">${matchRows}</ul>
  `;
  body.querySelectorAll('.matches li').forEach(li => {
    li.addEventListener('click', () => {
      selectNode(li.dataset.name);
      if (window.innerWidth <= 900) {
        document.getElementById('network-wrap').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  applyDim();
}

function applyDim() {
  nodeSel.style('display', n => dimmed.has(n.cluster) ? 'none' : null);
  linkSel.style('display', l => (dimmed.has(l.source.cluster) || dimmed.has(l.target.cluster)) ? 'none' : null);
}

svg.on('click', (e) => {
  if (e.target.tagName === 'svg' || e.target.classList.contains('viz-wrap')) {
    nodeSel.classed('faded', false).classed('selected', false);
    nodeSel.selectAll('text').classed('dim', false);
    linkSel.classed('highlight', false).classed('faded', false);
    document.getElementById('sel-name').textContent = '—';
    document.getElementById('sel-cluster').innerHTML = '<span class="dot" style="background:var(--ink-faint)"></span><span>nothing selected</span>';
    document.getElementById('sel-body').innerHTML = '<p class="placeholder">Tap any name in the network to see their trait profile and three closest matches.</p>';
  }
});

function drawHeatmap() {
  const hSvg = d3.select('#heatmap');
  hSvg.selectAll('*').remove();
  const hwrap = document.getElementById('heatmap-wrap');
  const Wp = hwrap.clientWidth, Hp = hwrap.clientHeight;
  const isSmall = Wp < 520;
  const padLeft = isSmall ? 56 : 78;
  const padTop  = isSmall ? 56 : 78;
  const padRight = isSmall ? 12 : 24;
  const padBottom = isSmall ? 12 : 24;
  const gridW = Wp - padLeft - padRight;
  const gridH = Hp - padTop - padBottom;
  const cell = Math.min(gridW, gridH) / DATA.names.length;

  const order = DATA.nodes.map((n, i) => i)
    .sort((a, b) => DATA.nodes[a].cluster - DATA.nodes[b].cluster || DATA.names[a].localeCompare(DATA.names[b]));

  const maxD = DATA.max_distance;
  const cellsG = hSvg.append('g').attr('transform', `translate(${padLeft},${padTop})`);

  for (let i = 0; i < order.length; i++) {
    for (let j = 0; j < order.length; j++) {
      const a = order[i], b = order[j];
      const dist = DATA.distance_matrix[a][b];
      const t = 1 - (dist / maxD);
      const fill = a === b
        ? '#f0e6d2'
        : `rgba(240, 230, 210, ${0.04 + 0.85 * t})`;
      const r = cellsG.append('rect')
        .attr('x', j * cell).attr('y', i * cell)
        .attr('width', Math.max(0.5, cell - 0.5))
        .attr('height', Math.max(0.5, cell - 0.5))
        .attr('fill', fill)
        .style('cursor', 'pointer');

      const showInfo = (e) => {
        if (isTouch) return;
        tooltip.classList.add('show');
        tooltip.innerHTML = `<strong>${DATA.names[a]}</strong> ↔ <strong>${DATA.names[b]}</strong><br>distance = ${dist}`;
        positionTooltip(e);
      };
      r.on('mouseenter', showInfo).on('mousemove', showInfo)
       .on('mouseleave', () => tooltip.classList.remove('show'));
    }
  }

  const labelFontSize = isSmall ? 7.5 : 9;
  const labelsG = hSvg.append('g').attr('font-size', labelFontSize);
  for (let i = 0; i < order.length; i++) {
    const name = DATA.names[order[i]];
    const cluster = DATA.nodes[order[i]].cluster;
    labelsG.append('text')
      .attr('x', padLeft - 6)
      .attr('y', padTop + i * cell + cell * 0.66)
      .attr('text-anchor', 'end')
      .attr('fill', CLUSTER_COLOR[cluster])
      .text(name);
    labelsG.append('text')
      .attr('x', padLeft + i * cell + cell * 0.5)
      .attr('y', padTop - 6)
      .attr('text-anchor', 'start')
      .attr('transform', `rotate(-55, ${padLeft + i * cell + cell * 0.5}, ${padTop - 6})`)
      .attr('fill', CLUSTER_COLOR[cluster])
      .text(name);
  }
}

const btnNet = document.getElementById('view-network');
const btnHeat = document.getElementById('view-heatmap');
btnNet.addEventListener('click', () => {
  btnNet.classList.add('active'); btnHeat.classList.remove('active');
  document.getElementById('network-wrap').classList.remove('hidden');
  document.getElementById('heatmap-wrap').classList.remove('active');
});
btnHeat.addEventListener('click', () => {
  btnHeat.classList.add('active'); btnNet.classList.remove('active');
  document.getElementById('network-wrap').classList.add('hidden');
  document.getElementById('heatmap-wrap').classList.add('active');
  drawHeatmap();
});

let resizeTimer;
function onResize() {
  clearTimeout(resizeTimer);
  resizeTimer = setTimeout(() => {
    sim.force('center', d3.forceCenter(W()/2, H()/2));
    sim.alpha(0.3).restart();
    if (document.getElementById('heatmap-wrap').classList.contains('active')) drawHeatmap();
  }, 120);
}
window.addEventListener('resize', onResize);
window.addEventListener('orientationchange', () => setTimeout(onResize, 250));

setTimeout(() => selectNode('Dev'), 800);
</script>

