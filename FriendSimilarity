// Score-tier interpretation framework
// Each mini-score sits between 1 and 4.
//   1.0–1.9 = Low | 2.0–2.6 = Mid-low | 2.7–3.2 = Mid-high | 3.3–4.0 = High
const TIER_NAME = { low: "Low", midLow: "Mid-low", midHigh: "Mid-high", high: "High" };
function tierFor(v) {
  if (v < 2.0) return "low";
  if (v < 2.7) return "midLow";
  if (v < 3.3) return "midHigh";
  return "high";
}

