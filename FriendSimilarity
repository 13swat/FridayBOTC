// One-line composite reading
function quickRead(s) {
  const t = {};
  for (const k in s) t[k] = tierFor(s[k]);
  const isHigh = v => v === "high" || v === "midHigh";
  const isLow  = v => v === "low" || v === "midLow";

  // Notable combos (priority order)
  if (isHigh(t.Social) && isHigh(t.Novelty)) return "Outgoing explorer — energy outward, curious about what's next.";
  if (isLow(t.Social) && isHigh(t.Novelty)) return "Independent explorer — quiet outside, restless inside; chases novelty on own terms.";
  if (isHigh(t.Structure) && isHigh(t.Thinking)) return "Analytical planner — thinks it through, likes a clear plan.";
  if (isLow(t.Social) && isHigh(t.Thinking)) return "Quiet observer — watches, considers, speaks once it's worth saying.";
  if (isLow(t.Structure) && isHigh(t.Novelty)) return "Spontaneous spark — improvises, chases novelty, plans loosely.";
  if (isHigh(t.Social) && isLow(t.Thinking)) return "Expressive people-person — leads with feeling and warmth.";
  if (isLow(t.Novelty) && isHigh(t.Structure)) return "Stable & dependable — values routine, predictability, calm.";
  if (isHigh(t.Social) && isLow(t.Bonding)) return "Social butterfly — wide reach, light-touch bonds.";
  if (isLow(t.Social) && isHigh(t.Bonding)) return "Small circle, deep loyalty — quality over quantity.";
  if (isLow(t.Novelty) && isHigh(t.Bonding)) return "The 'always there' friend — steady, loyal, consistent.";

  // Aggregate fallbacks
  const vals = Object.values(t);
  const lows = vals.filter(L).length;
  const highs = vals.filter(isHigh).length;
  if (lows >= 4) return "Easy-going & low-key — light energy across the board, hard to ruffle.";
  if (highs >= 4) return "High-intensity across the board — bold, expressive, plenty going on.";

  return "Balanced profile — no single trait dominates the others.";
}

